{
  "version": 2,
  "installCommand": "npm install -g pnpm@9.15.4 --loglevel=error && pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/subtitle-generator run build",
  "outputDirectory": "artifacts/subtitle-generator/dist/public",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
