{
  "version": 2,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run typecheck:libs && pnpm --filter @workspace/subtitle-generator run build",
  "outputDirectory": "artifacts/subtitle-generator/dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
